/**
 * Definition for singly-linked list.
 * public class ListNode {
 *     int val;
 *     ListNode next;
 *     ListNode(int x) {
 *         val = x;
 *         next = null;
 *     }
 * }
 */
class Result {
    ListNode last;
    int count;

    Result(ListNode last, int count) {
        this.last = last;
        this.count = count;
    }
}

public class Solution {
    public Result getLast(ListNode node) {
        int count = 1; //0 --> 1
        while (node.next != null) {
            node = node.next;
            count++;

        }
        return new Result(node, count);
    }

    public ListNode findIntersect(ListNode nodeA, ListNode nodeB){
        while(nodeA != nodeB){
            nodeA = nodeA.next;
            nodeB = nodeB.next;
        }
        return nodeA;
    }

    public ListNode getIntersectionNode(ListNode headA, ListNode headB) {
        ListNode aLast, bLast;

        Result a = getLast(headA);
        Result b = getLast(headB);

        if (a.last != b.last)
            return null;
        
        int diff = a.count - b.count;

        if(diff == 0){
            return findIntersect(headA,headB);
        }

        if(diff > 0){
            ListNode movedA = headA;
            while(diff > 0){
                movedA = movedA.next;
                diff--;
            }
            return findIntersect(movedA, headB);
        }
        else{
            ListNode movedB = headB;
            while(diff < 0){
                movedB = movedB.next;
                diff++;
            }
            return findIntersect(headA, movedB);
        }

    }
}