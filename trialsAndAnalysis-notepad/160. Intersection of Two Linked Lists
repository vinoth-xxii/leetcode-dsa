/**
 * Definition for singly-linked list.
 * public class ListNode {
 *     int val;
 *     ListNode next;
 *     ListNode(int x) {
 *         val = x;
 *         next = null;
 *     }
 * }
 */
public class Solution {
    public ListNode getIntersectionNode(ListNode headA, ListNode headB) {
        ListNode aLast = headA;
        ListNode bLast = headB;
        int aCount = 0;
        int bCount = 0;

        while (aLast != null) {
            aCount++;
            aLast = aLast.next;
        }
        while (bLast != null) {
            bCount++;
            bLast = bLast.next;
        }

        if (aLast != bLast) {
            return null;
        }

        if (aCount < bCount) {
            for (int i = 0; i < bCount - aCount; i++) {
                while (bLast != null) {
                    bLast = bLast.next;

                }
            }
            return bLast;
        } else {
            for (int i = 0; i < aCount - bCount; i++) {
                while (aLast != null) {
                    aLast = aLast.next;

                }
            }
            return aLast;
        }
    }
}


