class Solution {       //correct soultion, but time limit exceed since it's quadratic time complexity

    public int getDays(int index, int[] arr){
        int count = 0;
        for(int i = index + 1; i < arr.length; i++){
            count++;
            if(arr[i] > arr[index]){
                return count;
            }
        }
        return 0;
    }

    public int[] dailyTemperatures(int[] temperatures) {
        int[] result = new int[temperatures.length];

        for(int i = 0; i < temperatures.length; i++){
            result[i] = getDays(i, temperatures);
        }
        return result;
    }
}