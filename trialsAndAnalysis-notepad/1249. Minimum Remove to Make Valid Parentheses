class Solution {
    public String minRemoveToMakeValid(String s) {
        Stack<Character> openings = new Stack<>();
        Stack<Character> closings = new Stack<>();

        String result = "";
        int str_len = s.length();


        //below loop will remove the potential closing brackets
        for(int i = 0; i < str_len; i++){
            char c = s.charAt(i);
            if(c == '('){
                openings.push(c);
                result+=c;
            }
            else if(c == ')'){
                if(!openings.isEmpty()){ //has matching closing
                    openings.pop();
                    result+=c;
                }
                //else it will be ommited/left
            }
            else{
                result+=c;
            }
        }

        String result1 = "";
        int str_len_res = result.length();

        //below loop will keep track of closing and remove potential opening brackets
        for(int i = str_len_res - 1; i >= 0; i--){
            char c = result.charAt(i);
             if(c == ')'){
                closings.push(c);
                result1+=c;
            } else if(c == '('){
                if(!closings.isEmpty()){ //has matching closing
                    closings.pop();
                    result1+=c;
                }
                //else it will be ommited/left
            }
            else{
                result1+=c;
            }
        }

    return result1;
    }
}