class MinStack {

    public MinStack() {
        ArrayList arr = new List<Integer>();
        int last = 0;
        int min = Integer.MIN_VALUE();
    }
    
    public void push(int val) {
        min = (val < min) ? val : min;
        arr[last++] = val;

    }
    
    public void pop() {
        if(last >= 0){
            min = (arr[last-1] < min) ? arr[last-1] : min;
            last--;
        }
    }
    
    public int top() {
        return arr[last];
    }
    
    public int getMin() {
        return min;
    }
}

