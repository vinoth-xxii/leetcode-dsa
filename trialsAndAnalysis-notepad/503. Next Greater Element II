class Solution {

    public int getNextMax(int index, int[] arr){
        int moduloIndex = index;
        int max = -1;
        while(moduloIndex + 1 != index){
            if(arr[moduloIndex] > arr[index]){
                max = arr[moduloIndex];
            }
            moduloIndex = ( (arr.length - 1) +  moduloIndex ) % (arr.length - 1);
        }
        return max;
    }

    public int[] nextGreaterElements(int[] nums) {
        int[] result = new int[nums.lenght];
        for(int i = 0; i < nums.length; i++){
            result[i] = getNextMax(i, nums);
        }
        return result;
    }
}

