class Solution {

    public int getNextMax(int index, int[] arr){

        int size = arr.length - 1;
        int curr =  ((size + index + 1) % size )  - 1;   //i need this to be next
        int max = -1;

        while(curr != index){
            if(arr[curr] > arr[index]){
                max = arr[curr];
                return max;
            }
            curr = ( (curr + 1) % size ) - 1;
        }
        return max;
    }

    public int[] nextGreaterElements(int[] nums) {
        int[] result = new int[nums.length];
        for(int i = 0; i < nums.length; i++){
            result[i] = getNextMax(i, nums);
        }
        return result;
    }
}

