class Solution { // Quadratic time implementaion, leads to time out exception
    public int maxArea(int[] height) {
        //i will initialise total vol, 
        //using nested loops, i could find the max volume

        //how do i find the volume? vol of rectangle in l x b x h
        //where l is Math.min(outerloop, innerloop)
        //where b is innterloop - outerloop

        //since it has only two axis l X b

        int area = 0;
        int length = 0;
        int breath = 0;

        for(int i = 0; i < height.length; i++){
            for(int j = 0; j < height.length; j++){
                length = j - i;
                breath = Math.min(height[i], height[j]);
                area = Math.max(area, length * breath);
            }
        }
        return area;
    }
}

