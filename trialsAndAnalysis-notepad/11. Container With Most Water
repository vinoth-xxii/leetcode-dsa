class Solution {
    public int maxArea(int[] height) {
        //let try using two pointer and logic i understood from 3rd hint
        //Move the left and right pointer torwards center one by one

        int left = 0;
        int right = height.length - 1;
        int track = 1;
        int area = 0;

        while(left < right){
            //how do i move left and right alreanatively? using odd even logic? lol
            if(track % 2 == 0){
                left++;
                track++;
            }
            else{
                right--;
                track++;
            }

            int breath = Math.min(height[left], height[right]);
            int length = right - left;
            area = Math.max(breath * length, area);

        }

        return area;
    }
}

