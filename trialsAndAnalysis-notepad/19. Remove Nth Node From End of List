 *     ListNode(int val, ListNode next) { this.val = val; this.next = next; }
 * }
 */
class Solution {
    public ListNode removeNthFromEnd(ListNode head, int n) {
        /* i will use two pointer, i will make the right point move till nth step,
        and will make leftto move along
        
        For initial approach why should do with one pass? lol

        Step 1: Just find out the node you want to delete
        Step 2: Just implement the delete node impl
         */

        ListNode right,left;
        int count = 1; //if the count is 1, i should remove the last
        left = null;
        right = head;

        while(right != null){
            right = right.next;
            count++;
            if(count > n){ //mod the left starting time
                left = left.next;
            }
        }
