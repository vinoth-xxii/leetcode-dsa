class Solution {
    public int firstUniqChar(String s) {
        HashMap<Character, Integer> frequency = new HashMap<>();
        int str_len = s.length();

        for(int i = 0; i < str_len; i++){
            char c = s.charAt(i);
            frequency.put(c, frequency.getOrDefault(c, 0) + 1);
        }

        int result = -1;
        for(int i = 0; i < str_len; i++){
            char c = s.charAt(i);
            if(frequency.get(c) == 1){
                result = i;
                return result;
            }
        }
    
    return result;
    }
}

