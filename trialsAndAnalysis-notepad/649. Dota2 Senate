class Solution {
    public String predictPartyVictory(String senate) {
        Map<Character, Integer> senateCount = new HashMap<>();
        Queue<Character> queue = new LinkedList<>();

        for(int i = 0; i < senate.length(); i++){
            char c = senate.charAt(i);
            senateCount.put(c, getOrDefault(c, 0) + 1);
            //while calculating, might as well build the queue
            queue.put(c);
        }

        //this dictates : procedure will last until the end of voting
        while(!queue.isEmpty()){
            char currentSenate = queue.poll();
            //lets see what the currentsenate would decide
            char next = queue.peek();
            if(next != null && next == currentSenate){
                queue.put(currentSenate); //simple put the curr senate without any action performed
            }
            else if(next != null && next != currentSenate){
                queue.poll(); //exercising the remove rights
                senateCount.put(next, getOrDefault(next, 0) - 1); //adjusting count after removal
                queue.put(currentSenate)//putting currentSenate after actions performed
            }
        }

    }
}

