class Solution {
    public int minAddToMakeValid(String s) {
        int str_length = s.length();
        int open = 0;
        int close = 0;
        for(int i = 0; i < str_length; i++){
            if(s.charAt(i) == '('){
                open++;
            }//closed brac
            else{
                if(open > 0){
                    open--;
                }
                else{
                    close++;
                }
            }
        }
        
        if(open == 0 || close == 0){
            return Math.max(open, close);
        }
        else{
            return Math.min(open, close);
        }
    }
}

